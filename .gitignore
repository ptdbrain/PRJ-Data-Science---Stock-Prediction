# ============================================
# DATABASE — KHÔNG push file DB lên git
# Mỗi người tự tạo local: python -m database.schema
# ============================================
*.db
*.sqlite
*.sqlite3

# ============================================
# MODEL FILES — Quá lớn cho git
# Mỗi người tự train local
# ============================================
models/saved/*.pt
models/saved/*.pth
models/saved/*.pkl
models/saved/*.json
models/saved/_checkpoint_*

# ============================================
# PYTHON
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg

# ============================================
# ENVIRONMENT
# ============================================
.env
venv/
.venv/
env/

# ============================================
# IDE
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# GIT WORKTREES
# ============================================
.worktrees/

# ============================================
# OS
# ============================================
.DS_Store
Thumbs.db

# ============================================
# JUPYTER
# ============================================
.ipynb_checkpoints/
notebooks/*.html

# ============================================
# LOGS
# ============================================
logs/*.log

# ============================================
